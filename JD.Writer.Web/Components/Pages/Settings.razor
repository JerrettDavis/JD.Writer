    private static string NormalizePathValue(string? rawValue)
    {
        return string.IsNullOrWhiteSpace(rawValue) ? string.Empty : rawValue.Trim();
    }

    private sealed record PreviewThemeOption(string Id, string Label);
    private sealed record ProviderOption(string Id, string Label, string Description);
