@page "/"
@using Markdig

<PageTitle>JD.Writer Studio</PageTitle>

<div class="studio-frame">
    <header class="studio-header">
        <div>
            <p class="eyebrow">
                <svg class="icon icon-eyebrow" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M4 19.5V22h2.5L17.1 11.4l-2.5-2.5L4 19.5Zm15.7-9.3c.4-.4.4-1 0-1.4l-1.5-1.5c-.4-.4-1-.4-1.4 0l-1.2 1.2 2.5 2.5 1.6-1.8Z" />
                </svg>
                JD.Writer
            </p>
            <h1>Markdown Studio</h1>
            <p class="subtitle">Local-first drafting with command palette, slash commands, and plugins.</p>
        </div>
        <div class="header-status">
            <span class="status-pill">
                <svg class="icon icon-pill ai" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M12 2a3 3 0 0 0-3 3v1.1A6 6 0 0 0 6.1 9H5a3 3 0 0 0 0 6h1.1A6 6 0 0 0 9 17.9V19a3 3 0 1 0 6 0v-1.1a6 6 0 0 0 2.9-2.9H19a3 3 0 1 0 0-6h-1.1A6 6 0 0 0 15 6.1V5a3 3 0 0 0-3-3Zm-2 7.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Zm4 0a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Z" />
                </svg>
                AI: @_lastAiSource
            </span>
            <span class="status-pill">
                <svg class="icon icon-pill notes" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M6 3h8l4 4v14H6V3Zm2 4h6v2H8V7Zm0 4h8v2H8v-2Zm0 4h8v2H8v-2Z" />
                </svg>
                Notes: @_notes.Count
            </span>
            <span class="status-pill">
                <svg class="icon icon-pill layers" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="m12 3 9 5-9 5-9-5 9-5Zm-9 8.5 9 5 9-5V15l-9 5-9-5v-3.5Zm0 7 9 5 9-5V20l-9 1-9-1v-1.5Z" />
                </svg>
                Layers: @ActiveLayerCount
            </span>
            <span class="status-pill @(_isVoiceRecording ? "live" : string.Empty)">
                <svg class="icon icon-pill voice" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M12 14a3 3 0 0 0 3-3V6a3 3 0 1 0-6 0v5a3 3 0 0 0 3 3Zm5-3a1 1 0 1 1 2 0 7 7 0 0 1-6 6.9V21h3a1 1 0 1 1 0 2H8a1 1 0 0 1 0-2h3v-3.1A7 7 0 0 1 5 11a1 1 0 1 1 2 0 5 5 0 0 0 10 0Z" />
                </svg>
                Voice: @(_isVoiceRecording ? "Recording" : "Ready")
            </span>
            <span class="status-pill @(_isAudioCapturing ? "live" : string.Empty)">
                <svg class="icon icon-pill audio" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M6 10v4h2.8l4.1 3.4c.6.5 1.5.1 1.5-.7V7.9c0-.8-.9-1.2-1.5-.7L8.8 10H6Zm10.5-4.5-1.4 1.4a7 7 0 0 1 0 9.8l1.4 1.4a9 9 0 0 0 0-12.6Zm-2.8 2.8-1.4 1.4a3 3 0 0 1 0 4.2l1.4 1.4a5 5 0 0 0 0-7Z" />
                </svg>
                Audio: @(_isAudioCapturing ? "Capturing" : (_isAudioCaptureSupported ? "Standby" : "Unsupported"))
            </span>
            @if (!string.IsNullOrWhiteSpace(WorkingLabel))
            {
                <span class="status-pill pending" role="status" aria-live="polite">
                    <span class="inline-loader" aria-hidden="true"></span>
                    @WorkingLabel
                </span>
            }
            <span class="status-pill" role="status" aria-live="polite">@_statusMessage</span>
            <a class="status-pill status-link" href="/settings">
                <svg class="icon icon-pill settings" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M21 11h-3.2A3.8 3.8 0 0 0 14 7.2V4a2 2 0 1 0-4 0v3.2A3.8 3.8 0 0 0 6.2 11H3a2 2 0 1 0 0 4h3.2A3.8 3.8 0 0 0 10 18.8V22a2 2 0 1 0 4 0v-3.2a3.8 3.8 0 0 0 3.8-3.8H21a2 2 0 1 0 0-4Zm-9 4a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z" />
                </svg>
                Settings
            </a>
            <span class="status-pill">
                <svg class="icon icon-pill key" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Zm2 3v2h2V9H6Zm3 0v2h2V9H9Zm3 0v2h2V9h-2Zm3 0v2h3V9h-3Z" />
                </svg>
                Ctrl+K / Ctrl+M
            </span>
        </div>
    </header>

    <section class="studio-grid">
        <aside class="note-rail">
            <div class="rail-controls">
                <label class="visually-hidden" for="note-search-input">Search notes</label>
                <div class="input-with-icon">
                    <svg class="icon icon-field search" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M10.5 3a7.5 7.5 0 0 1 5.9 12.1l4.2 4.2a1 1 0 0 1-1.4 1.4L15 16.5A7.5 7.5 0 1 1 10.5 3Zm0 2a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11Z" />
                    </svg>
                    <input id="note-search-input" class="search-box" placeholder="Find note" @bind="_searchText" @bind:event="oninput" />
                </div>
                <button class="ghost-button" @onclick="CreateNoteAsync">
                    <svg class="icon icon-button add" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M11 5a1 1 0 1 1 2 0v6h6a1 1 0 1 1 0 2h-6v6a1 1 0 1 1-2 0v-6H5a1 1 0 1 1 0-2h6V5Z" />
                    </svg>
                    New
                </button>
            </div>
            <div class="note-list">
                @{
                    var filteredNotes = FilteredNotes.ToList();
                }
                @if (ShowWorkspaceSkeleton)
                {
                    @for (var i = 0; i < 6; i++)
                    {
                        <div class="note-item skeleton-card" aria-hidden="true">
                            <span class="skeleton-block skeleton-line w-70"></span>
                            <span class="skeleton-block skeleton-line w-90"></span>
                            <span class="skeleton-block skeleton-line w-45"></span>
                        </div>
                    }
                }
                else if (filteredNotes.Count == 0)
                {
                    <p class="list-empty">No notes matched your search.</p>
                }
                else
                {
                    @foreach (var note in filteredNotes)
                    {
                        <button class="note-item @(note.Id == _activeNoteId ? "active" : string.Empty)" @onclick="() => SelectNote(note.Id)">
                            <strong>@note.Title</strong>
                            <span>@FormatPreview(note.Content)</span>
                            <time>
                                <svg class="icon icon-meta time" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M12 3a9 9 0 1 1 0 18 9 9 0 0 1 0-18Zm0 2a7 7 0 1 0 0 14 7 7 0 0 0 0-14Zm1 3v4.6l3 1.7-1 1.7-4-2.3V8h2Z" />
                                </svg>
                                @note.UpdatedAt.ToLocalTime().ToString("MMM d h:mm tt")
                            </time>
                        </button>
                    }
                }
            </div>
        </aside>

        <main class="editor-pane">
            @if (ShowWorkspaceSkeleton)
            {
                <div class="editor-loading-state" role="status" aria-live="polite">
                    <div class="editor-toolbar-skeleton" aria-hidden="true">
                        <span class="skeleton-block skeleton-title"></span>
                        <span class="skeleton-block skeleton-chip"></span>
                        <span class="skeleton-block skeleton-chip"></span>
                        <span class="skeleton-block skeleton-chip"></span>
                    </div>
                    <div class="editor-surface-skeleton" aria-hidden="true">
                        <div class="skeleton-pane">
                            <span class="skeleton-block skeleton-line w-35"></span>
                            <span class="skeleton-block skeleton-line w-95"></span>
                            <span class="skeleton-block skeleton-line w-88"></span>
                            <span class="skeleton-block skeleton-line w-92"></span>
                            <span class="skeleton-block skeleton-line w-75"></span>
                        </div>
                        <div class="skeleton-pane">
                            <span class="skeleton-block skeleton-line w-35"></span>
                            <span class="skeleton-block skeleton-line w-90"></span>
                            <span class="skeleton-block skeleton-line w-82"></span>
                            <span class="skeleton-block skeleton-line w-94"></span>
                            <span class="skeleton-block skeleton-line w-72"></span>
                        </div>
                    </div>
                </div>
            }
            else if (ActiveNote is null)
            {
                <div class="empty-state">
                    <h2>Create your first note</h2>
                    <button class="solid-button" @onclick="CreateNoteAsync">
                        <svg class="icon icon-button add" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M11 5a1 1 0 1 1 2 0v6h6a1 1 0 1 1 0 2h-6v6a1 1 0 1 1-2 0v-6H5a1 1 0 1 1 0-2h6V5Z" />
                        </svg>
                        Create note
                    </button>
                </div>
            }
            else
            {
                <div class="editor-toolbar">
                    <label class="visually-hidden" for="note-title-input">Note title</label>
                    <input id="note-title-input" class="title-input" value="@ActiveNote.Title" @oninput="HandleTitleInput" placeholder="Untitled note" disabled="@ShowEditorActivity" />
                    <div class="toolbar-actions">
                        <button class="ghost-button" @onclick="OpenPaletteAsync">
                            <svg class="icon icon-button palette" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 3a9 9 0 0 0 0 18h1.6a2.4 2.4 0 0 0 0-4.8H12a2 2 0 0 1 0-4h2.5a6.5 6.5 0 0 0 0-13H12Zm-4 6a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Zm4-2a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Zm4 2a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Z" />
                            </svg>
                            Palette
                        </button>
                        <button class="ghost-button" @onclick="@(() => RefreshAssistantPanelsAsync(force: true))" disabled="@_isRefreshingInsights">
                            @if (_isRefreshingInsights)
                            {
                                <span class="inline-loader" aria-hidden="true"></span>
                                <span>Refreshing...</span>
                            }
                            else
                            {
                                <svg class="icon icon-button refresh" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M20 4v6h-6l2.3-2.3A6 6 0 1 0 18 13a1 1 0 1 1 2 0 8 8 0 1 1-2.8-6.1L20 4Z" />
                                </svg>
                                <span>Refresh</span>
                            }
                        </button>
                        <button class="ghost-button @(_isVoiceRecording ? "recording" : string.Empty)" @onclick="ToggleVoiceCaptureAsync">
                            <svg class="icon icon-button voice" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 14a3 3 0 0 0 3-3V6a3 3 0 1 0-6 0v5a3 3 0 0 0 3 3Zm5-3a1 1 0 1 1 2 0 7 7 0 0 1-6 6.9V21h3a1 1 0 1 1 0 2H8a1 1 0 0 1 0-2h3v-3.1A7 7 0 0 1 5 11a1 1 0 1 1 2 0 5 5 0 0 0 10 0Z" />
                            </svg>
                            <span>Mic (@(_isVoiceRecording ? "On" : "Off"))</span>
                        </button>
                        <button class="ghost-button" @onclick="ContinueWithAiAsync" disabled="@(_isBusy || _isApplyingSlash)">
                            @if (_isBusy)
                            {
                                <span class="inline-loader" aria-hidden="true"></span>
                                <span>Generating...</span>
                            }
                            else
                            {
                                <svg class="icon icon-button ai" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M12 2a3 3 0 0 0-3 3v1.1A6 6 0 0 0 6.1 9H5a3 3 0 0 0 0 6h1.1A6 6 0 0 0 9 17.9V19a3 3 0 1 0 6 0v-1.1a6 6 0 0 0 2.9-2.9H19a3 3 0 1 0 0-6h-1.1A6 6 0 0 0 15 6.1V5a3 3 0 0 0-3-3Z" />
                                </svg>
                                <span>AI Continue</span>
                            }
                        </button>
                        <button class="ghost-button" @onclick="DownloadActiveNoteAsync">
                            <svg class="icon icon-button export" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 3a1 1 0 0 1 1 1v8.6l2.3-2.3a1 1 0 0 1 1.4 1.4l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 1.4-1.4L11 12.6V4a1 1 0 0 1 1-1Zm-7 14a1 1 0 0 1 1 1v1h12v-1a1 1 0 1 1 2 0v2a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1Z" />
                            </svg>
                            Export
                        </button>
                    </div>
                </div>

                <div class="editor-surface">
                    <div class="editor-panel @(ShowEditorActivity ? "activity-running" : string.Empty)" aria-busy="@ShowEditorActivity">
                        <label for="note-draft-input">
                            <svg class="icon icon-label draft" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M4 19.5V22h2.5L17.1 11.4l-2.5-2.5L4 19.5Zm15.7-9.3c.4-.4.4-1 0-1.4l-1.5-1.5c-.4-.4-1-.4-1.4 0l-1.2 1.2 2.5 2.5 1.6-1.8Z" />
                            </svg>
                            Draft
                        </label>
                        <textarea class="editor-input"
                                  id="note-draft-input"
                                  @ref="_editorInput"
                                  value="@ActiveNote.Content"
                                  @oninput="HandleDraftInput"
                                  @onkeydown="HandleEditorKeyDown"
                                  disabled="@ShowEditorActivity"
                                  placeholder="Start typing markdown..."></textarea>

                        <div class="editor-command-row">
                            @if (!string.IsNullOrWhiteSpace(_autocompleteSuggestion))
                            {
                                <button class="hint-chip" @onclick="AcceptAutocompleteAsync">
                                    <svg class="icon icon-button hint" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path d="m12 2 2.1 4.8L19 9l-4.9 2.2L12 16l-2.1-4.8L5 9l4.9-2.2L12 2Zm8 11 1 2.3L23 16l-2 1 .7 2-1.7-1-1.7 1 .7-2-2-1 2-.7L20 13Zm-16 0 1 2.3L7 16l-2 1 .7 2L4 18l-1.7 1 .7-2-2-1 2-.7L4 13Z" />
                                    </svg>
                                    Autocomplete: @ActiveWord@_autocompleteSuggestion
                                </button>
                            }
                            <span class="editor-hint">`/` slash command, `Ctrl+K` palette, `Ctrl+J` continue, `Ctrl+M` voice</span>
                        </div>

                        @if (_slashSuggestions.Count > 0 || _isApplyingSlash)
                        {
                            <div class="slash-popover @(_isApplyingSlash ? "is-loading" : string.Empty)" aria-busy="@_isApplyingSlash">
                                @if (_isApplyingSlash)
                                {
                                    <div class="slash-item skeleton-row" aria-hidden="true">
                                        <span class="skeleton-block skeleton-line w-55"></span>
                                        <span class="skeleton-block skeleton-line w-80"></span>
                                    </div>
                                }
                                @foreach (var command in _slashSuggestions)
                                {
                                    <button class="slash-item" @onclick="() => ApplySlashCommandAsync(command)" disabled="@_isApplyingSlash">
                                        <strong>/@command.Name</strong>
                                        <span>@command.Description</span>
                                    </button>
                                }
                            </div>
                        }

                        @if (ShowEditorActivity)
                        {
                            <div class="panel-loader" role="status" aria-live="polite">
                                <span class="skeleton-block skeleton-line w-70"></span>
                                <span class="skeleton-block skeleton-line w-85"></span>
                                <span class="skeleton-block skeleton-line w-60"></span>
                            </div>
                        }
                    </div>

                    <div class="preview-panel @(ShowEditorActivity ? "activity-running" : string.Empty)" aria-busy="@ShowEditorActivity">
                        <div class="preview-head">
                            <p class="preview-label">
                                <svg class="icon icon-label preview" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M12 5c5.5 0 9.5 4.8 10.8 6.7a.6.6 0 0 1 0 .6C21.5 14.2 17.5 19 12 19S2.5 14.2 1.2 12.3a.6.6 0 0 1 0-.6C2.5 9.8 6.5 5 12 5Zm0 2C7.9 7 4.6 10.4 3.3 12 4.6 13.6 7.9 17 12 17s7.4-3.4 8.7-5C19.4 10.4 16.1 7 12 7Zm0 2.2a2.8 2.8 0 1 1 0 5.6 2.8 2.8 0 0 1 0-5.6Z" />
                                </svg>
                                Preview
                            </p>

                            <label class="preview-theme-picker" for="preview-render-theme">
                                <svg class="icon icon-field theme" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M12 3a9 9 0 1 0 0 18h1.6a2.4 2.4 0 0 0 0-4.8H12a2 2 0 0 1 0-4h2.5a6.5 6.5 0 0 0 0-13H12Zm-4 6a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Zm4-2a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Zm4 2a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Z" />
                                </svg>
                                <span class="visually-hidden">Preview render theme</span>
                                <select id="preview-render-theme"
                                        class="preview-theme-select"
                                        data-testid="preview-render-theme"
                                        value="@_previewTheme"
                                        @onchange="HandlePreviewThemeChangedAsync">
                                    @foreach (var theme in AvailablePreviewThemes)
                                    {
                                        <option value="@theme.Id">@theme.Label</option>
                                    }
                                </select>
                            </label>
                        </div>
                        <div class="preview-shell">
                            <article class="preview-content preview-theme-@_previewTheme" data-testid="preview-content">@((MarkupString)RenderMarkdown(ActiveNote.Content))</article>
                            @if (ShowEditorActivity)
                            {
                                <div class="panel-loader preview-loader" role="status" aria-live="polite">
                                    <span class="skeleton-block skeleton-line w-72"></span>
                                    <span class="skeleton-block skeleton-line w-90"></span>
                                    <span class="skeleton-block skeleton-line w-84"></span>
                                    <span class="skeleton-block skeleton-line w-66"></span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </main>

        <aside class="assistant-rail">
            @if (ShowWorkspaceSkeleton)
            {
                @for (var panelIndex = 0; panelIndex < 4; panelIndex++)
                {
                    <section class="tool-window skeleton-window" aria-hidden="true">
                        <header>
                            <span class="skeleton-block skeleton-line w-55"></span>
                            <span class="skeleton-block skeleton-line w-85"></span>
                        </header>
                        <ul>
                            @for (var row = 0; row < 4; row++)
                            {
                                <li class="skeleton-row">
                                    <span class="skeleton-block skeleton-line w-95"></span>
                                </li>
                            }
                        </ul>
                    </section>
                }
            }
            else
            {
                <section class="tool-window tool-panel panel-voice-console voice-console">
                    <header>
                        <h2>Voice Console</h2>
                        <small>Recordings, playback, raw mode, and AI interpretation scale.</small>
                    </header>

                    <div class="voice-console-controls">
                        <label class="voice-toggle">
                            <input type="checkbox"
                                   data-testid="voice-raw-mode-toggle"
                                   @bind="_voiceRawTranscriptionMode"
                                   @bind:after="HandleRawTranscriptionModeChangedAsync" />
                            <span>Raw transcription mode</span>
                        </label>
                        <label class="voice-toggle">
                            <input type="checkbox"
                                   data-testid="voice-ai-cleanup-toggle"
                                   @bind="_voiceAiInterpretationEnabled"
                                   @bind:after="HandleVoiceAiEnabledChangedAsync" />
                            <span>Enable AI interpretation cleanup</span>
                        </label>
                        <label class="voice-scale">
                            <span>Chunk length</span>
                            <div class="voice-scale-field">
                                <input type="number"
                                       data-testid="voice-chunk-length"
                                       min="80"
                                       max="1200"
                                       step="20"
                                       @bind="_voiceCleanupChunkLength"
                                       @bind:after="HandleVoiceCleanupScaleChangedAsync" />
                                <span class="voice-unit">chars</span>
                            </div>
                            <small>Characters processed per AI cleanup pass.</small>
                        </label>
                        <label class="voice-scale">
                            <span>Chunk overlap</span>
                            <div class="voice-scale-field">
                                <input type="number"
                                       data-testid="voice-chunk-overlap"
                                       min="0"
                                       max="@Math.Max(0, _voiceCleanupChunkLength - 1)"
                                       step="10"
                                       @bind="_voiceCleanupChunkOverlap"
                                       @bind:after="HandleVoiceCleanupScaleChangedAsync" />
                                <span class="voice-unit">chars</span>
                            </div>
                            <small>Shared context between adjacent cleanup chunks.</small>
                        </label>
                    </div>

                    <div class="voice-recordings" data-testid="voice-recordings-list">
                        @{
                            var recordings = BuildVoiceRecordingItems();
                        }
                        @if (recordings.Count == 0)
                        {
                            <p class="voice-recordings-empty">No recordings yet. Start voice capture to collect audio + transcript evidence.</p>
                        }
                        else
                        {
                            @foreach (var recording in recordings)
                            {
                                var playbackUrl = ResolveRecordingPlaybackUrl(recording);
                                <article class="voice-recording-card" data-testid="voice-recording-card">
                                    <div class="voice-recording-meta">
                                        <strong>@recording.FileName</strong>
                                        <span>@recording.CapturedAt.ToLocalTime().ToString("MMM d h:mm:ss tt") • @($"{recording.DurationSeconds:0.00}s") • @recording.MimeType</span>
                                        @if (!recording.IsPersistedInline)
                                        {
                                            <em>Session-only audio blob (export/download before reload)</em>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(playbackUrl))
                                    {
                                        <audio controls preload="none" src="@playbackUrl" data-testid="voice-recording-audio"></audio>
                                    }
                                    else
                                    {
                                        <p class="voice-recordings-empty">Playback unavailable for this item.</p>
                                    }
                                    <div class="voice-recording-actions">
                                        <button class="ghost-button" data-testid="voice-recording-download" @onclick="() => DownloadVoiceRecordingAsync(recording)">Download</button>
                                        <button class="danger-button" data-testid="voice-recording-delete" @onclick="() => DeleteVoiceRecordingAsync(recording)">Delete</button>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </section>

                @foreach (var panel in AllPanels)
                {
                    var panelSlug = SlugifyTitle(panel.Title);
                    var showPanelSkeleton = ShowInsightsSkeleton && panel.Items.Count == 0;
                    <section class="tool-window tool-panel panel-@panelSlug" aria-busy="@showPanelSkeleton">
                        <header>
                            <h2>@panel.Title</h2>
                            <small>@panel.Description</small>
                        </header>
                        <ul class="panel-items">
                            @if (showPanelSkeleton)
                            {
                                @for (var row = 0; row < 4; row++)
                                {
                                    <li class="skeleton-row" aria-hidden="true">
                                        <span class="skeleton-block skeleton-line w-95"></span>
                                    </li>
                                }
                            }
                            else
                            {
                                @foreach (var item in panel.Items)
                                {
                                    var itemKind = GetPanelItemKind(item);
                                    <li class="panel-item panel-item-@itemKind">
                                        <span class="panel-item-text">@FormatPanelItemText(item)</span>
                                    </li>
                                }
                            }
                        </ul>
                    </section>
                }
            }
        </aside>
    </section>
</div>

@if (_isPaletteOpen)
{
    <div class="palette-backdrop" @onclick="ClosePalette"></div>
    <section class="command-palette" @onclick:stopPropagation>
        <label class="visually-hidden" for="command-palette-input">Command palette input</label>
        <input class="palette-input"
               id="command-palette-input"
               @ref="_paletteInput"
               @bind="_paletteQuery"
               @bind:event="oninput"
               @onkeydown="HandlePaletteKeyDown"
               placeholder="Type a command..." />
        <div class="palette-list">
            @if (PaletteResults.Count == 0)
            {
                <div class="palette-empty">No commands matched.</div>
            }
            else
            {
                @for (var i = 0; i < PaletteResults.Count; i++)
                {
                    var command = PaletteResults[i];
                    <button class="palette-item @(i == _paletteIndex ? "active" : string.Empty)" @onclick="() => ExecutePaletteCommandAsync(command)">
                        <strong>@command.Title</strong>
                        <span>@command.Description</span>
                    </button>
                }
            }
        </div>
    </section>
}
