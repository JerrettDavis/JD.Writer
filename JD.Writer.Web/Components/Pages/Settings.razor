@page "/settings"
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AiAssistantClient AiClient

<PageTitle>JD.Writer Settings</PageTitle>

<div class="settings-frame">
    <header class="settings-header">
        <div>
            <p class="settings-eyebrow">JD.Writer Controls</p>
            <h1>Studio Settings</h1>
            <p class="settings-subtitle">Configure workspace behavior, AI integrations, voice capture defaults, and local storage controls.</p>
        </div>
        <div class="settings-header-actions">
            <button class="settings-button ghost" @onclick="NavigateHome">
                <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M10 5 3 12l7 7 1.4-1.4L6.8 13H21v-2H6.8l4.6-4.6L10 5Z" />
                </svg>
                Back to Studio
            </button>
            <button class="settings-button primary"
                    data-testid="settings-save"
                    disabled="@(_isLoading || _isSaving)"
                    @onclick="SaveAsync">
                @if (_isSaving)
                {
                    <span class="inline-loader" aria-hidden="true"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M17 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V7l-4-4Zm-5 16a3 3 0 1 1 0-6 3 3 0 0 1 0 6ZM7 5h8v4H7V5Z" />
                    </svg>
                    <span>Save settings</span>
                }
            </button>
        </div>
    </header>

    @if (_isLoading)
    {
        <section class="settings-loading" role="status" aria-live="polite">
            <div class="skeleton-panel">
                <span class="skeleton-line w-35"></span>
                <span class="skeleton-line w-80"></span>
                <span class="skeleton-line w-70"></span>
            </div>
            <div class="skeleton-panel">
                <span class="skeleton-line w-55"></span>
                <span class="skeleton-line w-90"></span>
                <span class="skeleton-line w-75"></span>
            </div>
            <div class="skeleton-panel">
                <span class="skeleton-line w-45"></span>
                <span class="skeleton-line w-82"></span>
                <span class="skeleton-line w-60"></span>
            </div>
        </section>
    }
    else
    {
        <section class="settings-grid">
            <nav class="settings-nav" aria-label="Settings sections">
                <a href="/settings#appearance">Appearance</a>
                <a href="/settings#editor">Editor</a>
                <a href="/settings#ai">AI</a>
                <a href="/settings#local-model">Local Model Wizard</a>
                <a href="/settings#voice">Voice</a>
                <a href="/settings#plugins">Plugins</a>
                <a href="/settings#storage">Storage</a>
                <a href="/settings#shortcuts">Shortcuts</a>
            </nav>

            <EditForm EditContext="_editContext" class="settings-main">
                <section id="appearance" class="settings-card">
                    <header>
                        <h2>
                            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 3a9 9 0 1 0 0 18h1.5a2.5 2.5 0 0 0 0-5H12a2 2 0 0 1 0-4h2a7 7 0 0 0 0-14h-2Z" />
                            </svg>
                            Appearance
                        </h2>
                        <p>Theme and readability defaults for the whole studio.</p>
                    </header>
                    <div class="settings-fields two-col">
                        <label class="field">
                            <span>Site theme</span>
                            <select data-testid="settings-theme"
                                    @bind="_settings.ThemePreference"
                                    @bind:after="ApplyRuntimePreferencesAsync">
                                <option value="system">System</option>
                                <option value="light">Light</option>
                                <option value="dark">Dark</option>
                            </select>
                            <small>Override OS theme when needed.</small>
                        </label>
                        <label class="field">
                            <span>Default preview render theme</span>
                            <select @bind="_settings.DefaultPreviewTheme">
                                @foreach (var option in PreviewThemeOptions)
                                {
                                    <option value="@option.Id">@option.Label</option>
                                }
                            </select>
                            <small>Used for new workspaces and resets.</small>
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox"
                                   @bind="_settings.ReduceMotion"
                                   @bind:after="ApplyRuntimePreferencesAsync" />
                            <span>Reduce motion effects</span>
                        </label>
                        <label class="field">
                            <span>UI density</span>
                            <select @bind="_settings.UiDensity">
                                <option value="compact">Compact</option>
                                <option value="comfortable">Comfortable</option>
                                <option value="relaxed">Relaxed</option>
                            </select>
                        </label>
                    </div>
                </section>

                <section id="editor" class="settings-card">
                    <header>
                        <h2>
                            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M4 19.5V22h2.5L17.1 11.4l-2.5-2.5L4 19.5Zm15.7-9.3c.4-.4.4-1 0-1.4l-1.5-1.5c-.4-.4-1-.4-1.4 0l-1.2 1.2 2.5 2.5 1.6-1.8Z" />
                            </svg>
                            Editor
                        </h2>
                        <p>Typing and markdown behavior preferences.</p>
                    </header>
                    <div class="settings-fields two-col">
                        <label class="field">
                            <span>Editor font size</span>
                            <input type="range" min="12" max="24" step="1" @bind="_settings.EditorFontSize" />
                            <small>@_settings.EditorFontSize px</small>
                        </label>
                        <label class="field">
                            <span>Tab size</span>
                            <input type="number" min="2" max="8" step="1" @bind="_settings.TabSize" />
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.WrapLines" />
                            <span>Wrap long lines in editor</span>
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.EnableAutocomplete" />
                            <span>Enable local autocomplete hints</span>
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.EnableSlashSuggestions" />
                            <span>Show slash command suggestions</span>
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.AutoRefreshInsights" />
                            <span>Auto-refresh AI insight panels while typing</span>
                        </label>
                    </div>
                </section>

                <section id="ai" class="settings-card">
                    <header>
                        <h2>
                            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 2a3 3 0 0 0-3 3v1.1A6 6 0 0 0 6.1 9H5a3 3 0 0 0 0 6h1.1A6 6 0 0 0 9 17.9V19a3 3 0 1 0 6 0v-1.1a6 6 0 0 0 2.9-2.9H19a3 3 0 1 0 0-6h-1.1A6 6 0 0 0 15 6.1V5a3 3 0 0 0-3-3Z" />
                            </svg>
                            AI and Providers
                        </h2>
                        <p>Control which provider is preferred and how assistant transforms run.</p>
                    </header>
                    <div class="settings-fields two-col">
                        <label class="field">
                            <span>Provider preference</span>
                            <select @bind="_settings.ProviderPreference">
                                <option value="auto">Auto</option>
                                <option value="ollama">Ollama</option>
                                <option value="native">Native llama (GPU/CPU chain)</option>
                                <option value="local">Local-only chain (no cloud)</option>
                                <option value="openai">OpenAI</option>
                                <option value="fallback">Local fallback only</option>
                            </select>
                        </label>
                        <label class="field">
                            <span>Ollama endpoint</span>
                            <input type="url" @bind="_settings.OllamaEndpoint" placeholder="http://localhost:11434" />
                        </label>
                        <label class="field">
                            <span>Default Ollama model</span>
                            <input type="text" @bind="_settings.OllamaModel" placeholder="llama3.2:latest" />
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.EnableAiContinue" />
                            <span>Enable AI Continue in editor toolbar</span>
                        </label>
                    </div>

                    <div id="local-model" class="local-readiness-shell" data-testid="local-readiness-wizard">
                        <header class="local-readiness-header">
                            <h3>
                                <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M4 8V6a2 2 0 0 1 2-2h5v4H4Zm9-4h5a2 2 0 0 1 2 2v2h-7V4ZM4 10h7v4H4v-4Zm9 0h7v4h-7v-4ZM4 16h7v4H6a2 2 0 0 1-2-2v-2Zm9 0h7v2a2 2 0 0 1-2 2h-5v-4Z" />
                                </svg>
                                Local Model Readiness Wizard
                            </h3>
                            <p>Walk through provider strategy, runtime selection, diagnostics, and a live probe.</p>
                        </header>

                        <div class="local-step-strip" role="tablist" aria-label="Local model wizard steps">
                            @foreach (var step in LocalWizardSteps)
                            {
                                var isActive = _localWizardStep == step.Id;
                                <button type="button"
                                        class="local-step-chip @(isActive ? "active" : null)"
                                        role="tab"
                                        aria-selected="@isActive"
                                        @onclick="() => SetLocalWizardStep(step.Id)">
                                    <span class="step-index">@step.Id</span>
                                    <span>@step.Label</span>
                                </button>
                            }
                        </div>

                        <div class="local-step-body">
                            @if (_localWizardStep == 1)
                            {
                                <div class="local-step-panel">
                                    <h4>Choose provider strategy</h4>
                                    <p>Pick how aggressively JD.Writer should stay local-first.</p>
                                    <div class="provider-grid">
                                        @foreach (var option in ProviderOptions)
                                        {
                                            var selected = string.Equals(_settings.ProviderPreference, option.Id, StringComparison.OrdinalIgnoreCase);
                                            <button type="button"
                                                    class="provider-card @(selected ? "selected" : null)"
                                                    @onclick="() => SetProviderPreference(option.Id)">
                                                <span class="provider-label">@option.Label</span>
                                                <small>@option.Description</small>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                            else if (_localWizardStep == 2)
                            {
                                <div class="local-step-panel">
                                    <h4>Select runtime pieces</h4>
                                    <p>Set explicit paths when shipping to controlled environments.</p>
                                    <div class="settings-fields two-col">
                                        <label class="field">
                                            <span>Native CLI path</span>
                                            <input type="text"
                                                   @bind="_settings.NativeLlamaCliPath"
                                                   placeholder="C:\\tools\\llama\\llama-cli.exe" />
                                            <small>Leave empty to auto-discover from PATH.</small>
                                        </label>
                                        <label class="field">
                                            <span>Model directory</span>
                                            <input type="text"
                                                   @bind="_settings.NativeLlamaModelDirectory"
                                                   placeholder="C:\\models\\jdwriter" />
                                            <small>Scanned first for GGUF models if explicit paths are empty.</small>
                                        </label>
                                        <label class="field">
                                            <span>GPU model path</span>
                                            <input type="text"
                                                   @bind="_settings.NativeLlamaGpuModelPath"
                                                   placeholder="C:\\models\\llama-3.2-8b-instruct-q4.gguf" />
                                            <small>Preferred when a supported GPU is available.</small>
                                        </label>
                                        <label class="field">
                                            <span>CPU model path</span>
                                            <input type="text"
                                                   @bind="_settings.NativeLlamaCpuModelPath"
                                                   placeholder="C:\\models\\llama-3.2-3b-instruct-q4.gguf" />
                                            <small>Used as deterministic local fallback.</small>
                                        </label>
                                    </div>
                                </div>
                            }
                            else if (_localWizardStep == 3)
                            {
                                <div class="local-step-panel">
                                    <div class="local-step-panel-header">
                                        <div>
                                            <h4>Readiness diagnostics</h4>
                                            <p>Fetch live provider summary and hardware scan from API runtime.</p>
                                        </div>
                                        <button type="button"
                                                class="settings-button ghost"
                                                data-testid="local-readiness-refresh"
                                                @onclick="RefreshProviderSummaryAsync"
                                                disabled="@_isProviderSummaryLoading">
                                            @if (_isProviderSummaryLoading)
                                            {
                                                <span class="inline-loader" aria-hidden="true"></span>
                                                <span>Refreshing...</span>
                                            }
                                            else
                                            {
                                                <span>Refresh</span>
                                            }
                                        </button>
                                    </div>

                                    <div class="readiness-badges">
                                        <span class="readiness-pill @GetReadinessClass()"
                                              data-testid="local-readiness-badge">
                                            @GetReadinessLabel()
                                        </span>
                                        <span class="readiness-pill muted">
                                            Preference: @(_providerSummary?.Summary.Preference ?? "n/a")
                                        </span>
                                        <span class="readiness-pill muted">
                                            Source: @(_providerSummary?.Source ?? "not loaded")
                                        </span>
                                    </div>

                                    @if (_providerSummary?.ErrorMessage is { Length: > 0 } errorMessage)
                                    {
                                        <p class="readiness-warning">@errorMessage</p>
                                    }

                                    <dl class="readiness-grid" data-testid="local-readiness-summary">
                                        <dt>Provider order</dt>
                                        <dd>@GetProviderOrderText()</dd>
                                        <dt>Native configured</dt>
                                        <dd>@FormatBool(_providerSummary?.Summary.NativeLlamaConfigured)</dd>
                                        <dt>Native enabled</dt>
                                        <dd>@FormatBool(_providerSummary?.Summary.NativeLlamaEnabled)</dd>
                                        <dt>Ollama configured</dt>
                                        <dd>@FormatBool(_providerSummary?.Summary.OllamaConfigured)</dd>
                                        <dt>Supported GPU</dt>
                                        <dd>@FormatBool(_providerSummary?.Summary.Hardware?.HasSupportedGpu)</dd>
                                        <dt>Acceleration</dt>
                                        <dd>@(_providerSummary?.Summary.Hardware?.PreferredAcceleration ?? "unknown")</dd>
                                        <dt>Detected GPUs</dt>
                                        <dd>@GetHardwareNamesText()</dd>
                                    </dl>
                                </div>
                            }
                            else
                            {
                                <div class="local-step-panel">
                                    <h4>Run live generation probe</h4>
                                    <p>Runs the same AI continue pipeline and reports the source used.</p>
                                    <label class="field">
                                        <span>Probe draft seed</span>
                                        <textarea class="probe-input"
                                                  @bind="_probePrompt"
                                                  rows="5"></textarea>
                                    </label>
                                    <div class="probe-actions">
                                        <button type="button"
                                                class="settings-button primary"
                                                data-testid="local-probe-run"
                                                @onclick="RunLocalProbeAsync"
                                                disabled="@_isProbeRunning">
                                            @if (_isProbeRunning)
                                            {
                                                <span class="inline-loader" aria-hidden="true"></span>
                                                <span>Running...</span>
                                            }
                                            else
                                            {
                                                <span>Run Probe</span>
                                            }
                                        </button>
                                        @if (!string.IsNullOrWhiteSpace(_probeResultSource))
                                        {
                                            <span class="readiness-pill muted" data-testid="local-probe-source">
                                                Source: @_probeResultSource
                                            </span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(_probeResultText))
                                    {
                                        <pre class="probe-output">@_probeResultText</pre>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_probeError))
                                    {
                                        <p class="readiness-warning">@_probeError</p>
                                    }
                                </div>
                            }
                        </div>

                        <div class="local-step-footer">
                            <button type="button"
                                    class="settings-button ghost"
                                    data-testid="local-wizard-prev"
                                    disabled="@(_localWizardStep <= 1)"
                                    @onclick="PrevLocalWizardStep">
                                Previous
                            </button>
                            <span class="local-step-caption" data-testid="local-wizard-step-label">
                                Step @_localWizardStep of @LocalWizardSteps.Count: @GetCurrentStepLabel()
                            </span>
                            <button type="button"
                                    class="settings-button ghost"
                                    data-testid="local-wizard-next"
                                    disabled="@(_localWizardStep >= LocalWizardSteps.Count)"
                                    @onclick="NextLocalWizardStep">
                                Next
                            </button>
                        </div>
                    </div>
                </section>

                <section id="voice" class="settings-card">
                    <header>
                        <h2>
                            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 14a3 3 0 0 0 3-3V6a3 3 0 1 0-6 0v5a3 3 0 0 0 3 3Zm5-3a1 1 0 1 1 2 0 7 7 0 0 1-6 6.9V21h3a1 1 0 1 1 0 2H8a1 1 0 0 1 0-2h3v-3.1A7 7 0 0 1 5 11a1 1 0 1 1 2 0 5 5 0 0 0 10 0Z" />
                            </svg>
                            Voice
                        </h2>
                        <p>Live dictation defaults and cleanup behavior.</p>
                    </header>
                    <div class="settings-fields two-col">
                        <label class="field">
                            <span>Transcription mode</span>
                            <select data-testid="settings-voice-mode" @bind="_settings.VoiceTranscriptionMode">
                                <option value="assisted">Assisted (raw + AI interpretation)</option>
                                <option value="raw">Raw only (no AI interpretation)</option>
                            </select>
                            <small>Raw mode keeps exact speech text without AI cleanup.</small>
                        </label>
                        <label class="field">
                            <span>Dictation language</span>
                            <input type="text" @bind="_settings.VoiceLanguage" placeholder="en-US" />
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.EnableLiveInterimTranscript" />
                            <span>Insert interim transcript live at cursor</span>
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.EnableVoiceCleanup" />
                            <span>Run AI cleanup after final transcript</span>
                        </label>
                        <label class="field">
                            <span>AI cleanup chunk length</span>
                            <input type="number" min="80" max="1200" step="20" data-testid="settings-voice-chunk-length" @bind="_settings.VoiceCleanupChunkLength" />
                            <small>Longer chunks preserve context; shorter chunks reduce latency.</small>
                        </label>
                        <label class="field">
                            <span>AI cleanup overlap</span>
                            <input type="number" min="0" max="600" step="10" data-testid="settings-voice-chunk-overlap" @bind="_settings.VoiceCleanupChunkOverlap" />
                            <small>Overlap smooths transitions between interpreted chunks.</small>
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.PersistVoiceAuditTrail" />
                            <span>Persist Voice Review audit trail</span>
                        </label>
                    </div>
                </section>

                <section id="plugins" class="settings-card">
                    <header>
                        <h2>
                            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M21 11h-3.2A3.8 3.8 0 0 0 14 7.2V4a2 2 0 1 0-4 0v3.2A3.8 3.8 0 0 0 6.2 11H3a2 2 0 1 0 0 4h3.2A3.8 3.8 0 0 0 10 18.8V22a2 2 0 1 0 4 0v-3.2a3.8 3.8 0 0 0 3.8-3.8H21a2 2 0 1 0 0-4Zm-9 4a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z" />
                            </svg>
                            Plugins
                        </h2>
                        <p>Control plugin command and panel loading policy.</p>
                    </header>
                    <div class="settings-fields two-col">
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.EnablePluginManifest" />
                            <span>Load plugin manifest from `/plugins/plugins.json`</span>
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.AllowRemotePluginPrompts" />
                            <span>Allow plugin-defined AI prompts</span>
                        </label>
                        <label class="field">
                            <span>Plugin manifest path</span>
                            <input type="text" @bind="_settings.PluginManifestPath" />
                        </label>
                    </div>
                </section>

                <section id="storage" class="settings-card">
                    <header>
                        <h2>
                            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 2C7 2 3 3.8 3 6v12c0 2.2 4 4 9 4s9-1.8 9-4V6c0-2.2-4-4-9-4Zm0 2c4.6 0 7 .9 7 2s-2.4 2-7 2-7-.9-7-2 2.4-2 7-2Zm0 16c-4.6 0-7-.9-7-2v-2.2c1.6 1 4.3 1.6 7 1.6s5.4-.6 7-1.6V18c0 1.1-2.4 2-7 2Z" />
                            </svg>
                            Storage and Safety
                        </h2>
                        <p>Configure persistence ceilings and recovery behavior.</p>
                    </header>
                    <div class="settings-fields two-col">
                        <label class="field">
                            <span>Max history layers per note</span>
                            <input type="number" min="50" max="500" step="10" @bind="_settings.MaxLayersPerNote" />
                        </label>
                        <label class="field">
                            <span>Max voice sessions per note</span>
                            <input type="number" min="20" max="400" step="10" @bind="_settings.MaxVoiceSessionsPerNote" />
                        </label>
                        <label class="field checkbox">
                            <input type="checkbox" @bind="_settings.EnableTelemetry" />
                            <span>Allow anonymous usage telemetry</span>
                        </label>
                    </div>
                </section>

                <section id="shortcuts" class="settings-card">
                    <header>
                        <h2>
                            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Zm2 3v2h2V9H6Zm3 0v2h2V9H9Zm3 0v2h2V9h-2Zm3 0v2h3V9h-3Z" />
                            </svg>
                            Keyboard Shortcuts
                        </h2>
                        <p>Current built-in shortcuts for fast authoring.</p>
                    </header>
                    <ul class="shortcut-list">
                        <li><kbd>Ctrl+K</kbd> Open command palette</li>
                        <li><kbd>Ctrl+J</kbd> AI continue</li>
                        <li><kbd>Ctrl+M</kbd> Toggle voice capture</li>
                        <li><kbd>Ctrl+Enter</kbd> Apply top slash suggestion</li>
                        <li><kbd>Ctrl+Space</kbd> Accept autocomplete hint</li>
                    </ul>
                </section>
            </EditForm>

            <aside class="settings-side">
                <section class="settings-card side-card">
                    <h3>Status</h3>
                    <p role="status" aria-live="polite">@_statusMessage</p>
                    @if (_lastSavedAt is not null)
                    {
                        <small>Last saved: @_lastSavedAt.Value.ToLocalTime().ToString("MMM d, h:mm:ss tt")</small>
                    }
                </section>

                <section class="settings-card side-card">
                    <h3>Backup and Recovery</h3>
                    <div class="side-actions">
                        <button class="settings-button ghost" @onclick="ExportSettingsAsync">
                            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 3a1 1 0 0 1 1 1v8.6l2.3-2.3a1 1 0 0 1 1.4 1.4l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 1.4-1.4L11 12.6V4a1 1 0 0 1 1-1Zm-7 14a1 1 0 0 1 1 1v1h12v-1a1 1 0 1 1 2 0v2a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1Z" />
                            </svg>
                            Export settings JSON
                        </button>

                        <label class="settings-button ghost import-button">
                            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 21a1 1 0 0 1-1-1v-8.6l-2.3 2.3a1 1 0 0 1-1.4-1.4l4-4a1 1 0 0 1 1.4 0l4 4a1 1 0 0 1-1.4 1.4L13 11.4V20a1 1 0 0 1-1 1Zm-7-6a1 1 0 0 1 1 1v1h12v-1a1 1 0 1 1 2 0v2a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1Z" />
                            </svg>
                            Import settings JSON
                            <InputFile OnChange="ImportSettingsAsync" accept=".json,application/json" />
                        </label>

                        <button class="settings-button danger" @onclick="ResetDefaultsAsync">Reset to defaults</button>
                        <button class="settings-button danger" @onclick="ClearWorkspaceStateAsync">Clear note workspace cache</button>
                    </div>
                </section>
            </aside>
        </section>
    }
</div>

@code
{
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web) { WriteIndented = true };

    private static readonly List<PreviewThemeOption> PreviewThemeOptions =
    [
        new("studio", "Studio"),
        new("paper", "Paper"),
        new("solarized", "Solarized"),
        new("terminal", "Terminal"),
        new("noir", "Noir"),
        new("blueprint", "Blueprint")
    ];

    private static readonly List<ProviderOption> ProviderOptions =
    [
        new("auto", "Auto", "Prefer Ollama first, then native GPU/CPU, then cloud."),
        new("ollama", "Ollama-first", "Use Ollama first and keep native/cloud fallback available."),
        new("native", "Native-first", "Prioritize local llama runtime before Ollama/cloud."),
        new("local", "Local-only chain", "Use native GPU/CPU and Ollama only, with no cloud dependency."),
        new("openai", "OpenAI-first", "Use OpenAI first, then local options."),
        new("fallback", "Deterministic fallback", "No model calls; deterministic local transforms only.")
    ];

    private static readonly List<WizardStep> LocalWizardSteps =
    [
        new(1, "Provider"),
        new(2, "Paths"),
        new(3, "Diagnostics"),
        new(4, "Probe")
    ];

    private StudioSettings _settings = CreateDefaultSettings();
    private EditContext _editContext = default!;
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _hasUnsavedChanges;
    private int _localWizardStep = 1;
    private bool _isProviderSummaryLoading;
    private ProviderSummaryResult? _providerSummary;
    private bool _isProbeRunning;
    private string _probePrompt = "# Local readiness probe\n\nConfirm this runtime can continue local markdown drafts.";
    private string? _probeResultText;
    private string? _probeResultSource;
    private string? _probeError;
    private string _statusMessage = "Loading settings...";
    private DateTimeOffset? _lastSavedAt;

    protected override void OnInitialized()
    {
        RebuildEditContext();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _isLoading = true;
        _statusMessage = "Loading settings...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var raw = await JS.InvokeAsync<string?>("JDWriterStudio.loadSettings");
            if (string.IsNullOrWhiteSpace(raw))
            {
                _settings = CreateDefaultSettings();
                _statusMessage = "Using default settings";
            }
            else
            {
                _settings = NormalizeSettings(JsonSerializer.Deserialize<StudioSettings>(raw, JsonOptions));
                _statusMessage = "Settings loaded";
            }

            RebuildEditContext();
            _hasUnsavedChanges = false;
            await ApplyRuntimePreferencesAsync();
            await RefreshProviderSummaryAsync();
        }
        catch
        {
            _settings = CreateDefaultSettings();
            RebuildEditContext();
            _statusMessage = "Settings load failed; default settings restored";
            _hasUnsavedChanges = true;
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveAsync()
    {
        if (_isSaving || _isLoading)
        {
            return;
        }

        _isSaving = true;
        _statusMessage = "Saving settings...";
        await InvokeAsync(StateHasChanged);

        try
        {
            _settings = NormalizeSettings(_settings);
            var serialized = JsonSerializer.Serialize(_settings, JsonOptions);
            await JS.InvokeVoidAsync("JDWriterStudio.saveSettings", serialized);
            await ApplyRuntimePreferencesAsync();
            await RefreshProviderSummaryAsync();
            _hasUnsavedChanges = false;
            _lastSavedAt = DateTimeOffset.UtcNow;
            _statusMessage = "Settings saved";
        }
        catch
        {
            _statusMessage = "Settings save failed";
        }
        finally
        {
            _isSaving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ExportSettingsAsync()
    {
        try
        {
            _settings = NormalizeSettings(_settings);
            var serialized = JsonSerializer.Serialize(_settings, JsonOptions);
            await JS.InvokeVoidAsync("JDWriterStudio.downloadText", "jdwriter-settings.json", serialized, "application/json;charset=utf-8");
            _statusMessage = "Settings exported";
        }
        catch
        {
            _statusMessage = "Settings export failed";
        }
    }

    private async Task ImportSettingsAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 1_000_000);
            using var reader = new StreamReader(stream);
            var raw = await reader.ReadToEndAsync();
            var imported = JsonSerializer.Deserialize<StudioSettings>(raw, JsonOptions);
            _settings = NormalizeSettings(imported);
            RebuildEditContext();
            _hasUnsavedChanges = true;
            _statusMessage = "Settings imported; save to persist";
            await ApplyRuntimePreferencesAsync();
        }
        catch
        {
            _statusMessage = "Invalid settings file";
        }
    }

    private async Task ResetDefaultsAsync()
    {
        _settings = CreateDefaultSettings();
        RebuildEditContext();
        _hasUnsavedChanges = true;
        _statusMessage = "Defaults restored; save to persist";
        await ApplyRuntimePreferencesAsync();
        await RefreshProviderSummaryAsync();
    }

    private async Task ClearWorkspaceStateAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("JDWriterStudio.clearState");
            _statusMessage = "Workspace cache cleared";
        }
        catch
        {
            _statusMessage = "Workspace cache clear failed";
        }
    }

    private async Task ApplyRuntimePreferencesAsync()
    {
        await JS.InvokeVoidAsync("JDWriterStudio.applySiteTheme", _settings.ThemePreference);
        await JS.InvokeVoidAsync("JDWriterStudio.applyReducedMotion", _settings.ReduceMotion);
    }

    private void SetProviderPreference(string providerPreference)
    {
        if (string.IsNullOrWhiteSpace(providerPreference))
        {
            return;
        }

        _settings.ProviderPreference = providerPreference.Trim().ToLowerInvariant();
        _hasUnsavedChanges = true;
        _statusMessage = "Unsaved changes";
    }

    private void SetLocalWizardStep(int stepId)
    {
        _localWizardStep = Math.Clamp(stepId, 1, LocalWizardSteps.Count);
    }

    private void NextLocalWizardStep()
    {
        SetLocalWizardStep(_localWizardStep + 1);
    }

    private void PrevLocalWizardStep()
    {
        SetLocalWizardStep(_localWizardStep - 1);
    }

    private async Task RefreshProviderSummaryAsync()
    {
        _isProviderSummaryLoading = true;
        _probeError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _providerSummary = await AiClient.GetProviderSummaryAsync();
            _statusMessage = _providerSummary.IsReachable
                ? "Provider summary refreshed"
                : "Provider summary unavailable; using local fallback diagnostics";
        }
        catch
        {
            _providerSummary = null;
            _statusMessage = "Provider summary refresh failed";
        }
        finally
        {
            _isProviderSummaryLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunLocalProbeAsync()
    {
        if (_isProbeRunning)
        {
            return;
        }

        _isProbeRunning = true;
        _probeError = null;
        _probeResultText = null;
        _probeResultSource = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var response = await AiClient.ContinueDraftAsync(new ContinueDraftRequest(_probePrompt));
            _probeResultSource = response.Source;
            _probeResultText = response.Continuation;
            _statusMessage = $"Probe completed via {response.Source}";
        }
        catch
        {
            _probeError = "Probe failed. Check API availability and provider configuration.";
            _statusMessage = "Probe failed";
        }
        finally
        {
            _isProbeRunning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetCurrentStepLabel()
    {
        return LocalWizardSteps.FirstOrDefault(step => step.Id == _localWizardStep)?.Label ?? "Step";
    }

    private string GetReadinessLabel()
    {
        if (_providerSummary is null)
        {
            return "Not Checked";
        }

        if (!_providerSummary.IsReachable)
        {
            return "API Unreachable";
        }

        if (_providerSummary.Summary.NativeLlamaConfigured)
        {
            return "Native Ready";
        }

        if (_providerSummary.Summary.OllamaConfigured)
        {
            return "Ollama Ready";
        }

        return "Needs Setup";
    }

    private string GetReadinessClass()
    {
        if (_providerSummary is null)
        {
            return "neutral";
        }

        if (!_providerSummary.IsReachable)
        {
            return "warning";
        }

        return _providerSummary.Summary.NativeLlamaConfigured || _providerSummary.Summary.OllamaConfigured
            ? "good"
            : "warning";
    }

    private static string FormatBool(bool? value)
    {
        return value switch
        {
            true => "Yes",
            false => "No",
            null => "Unknown"
        };
    }

    private string GetProviderOrderText()
    {
        var providers = _providerSummary?.Summary.ProviderOrder;
        return providers is null || providers.Count == 0
            ? "Not reported"
            : string.Join(" -> ", providers);
    }

    private string GetHardwareNamesText()
    {
        var names = _providerSummary?.Summary.Hardware?.GpuNames;
        return names is null || names.Count == 0
            ? "None detected"
            : string.Join(", ", names);
    }

    private void NavigateHome()
    {
        Navigation.NavigateTo("/");
    }

    private void RebuildEditContext()
    {
        _editContext = new EditContext(_settings);
        _editContext.OnFieldChanged += (_, _) =>
        {
            _hasUnsavedChanges = true;
            _statusMessage = "Unsaved changes";
            InvokeAsync(StateHasChanged);
        };
    }

    private static StudioSettings CreateDefaultSettings() => new()
    {
        ThemePreference = "system",
