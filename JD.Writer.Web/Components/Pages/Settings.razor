    };

    private static StudioSettings NormalizeSettings(StudioSettings? input)
    {
        var defaults = CreateDefaultSettings();
        if (input is null)
        {
            return defaults;
        }

        var normalizedTheme = (input.ThemePreference ?? defaults.ThemePreference).Trim().ToLowerInvariant();
        if (normalizedTheme is not ("system" or "light" or "dark"))
        {
            normalizedTheme = defaults.ThemePreference;
        }

        var normalizedDensity = (input.UiDensity ?? defaults.UiDensity).Trim().ToLowerInvariant();
        if (normalizedDensity is not ("compact" or "comfortable" or "relaxed"))
        {
            normalizedDensity = defaults.UiDensity;
        }

        var normalizedVoiceMode = (input.VoiceTranscriptionMode ?? defaults.VoiceTranscriptionMode).Trim().ToLowerInvariant();
        if (normalizedVoiceMode is not ("assisted" or "raw"))
        {
            normalizedVoiceMode = defaults.VoiceTranscriptionMode;
        }

        var previewTheme = string.IsNullOrWhiteSpace(input.DefaultPreviewTheme) ? defaults.DefaultPreviewTheme : input.DefaultPreviewTheme.Trim().ToLowerInvariant();
        if (PreviewThemeOptions.All(option => !string.Equals(option.Id, previewTheme, StringComparison.OrdinalIgnoreCase)))
        {
            previewTheme = defaults.DefaultPreviewTheme;
        }

        var normalizedChunkLength = Math.Clamp(input.VoiceCleanupChunkLength, 80, 1200);
        var normalizedChunkOverlap = Math.Clamp(input.VoiceCleanupChunkOverlap, 0, Math.Max(0, normalizedChunkLength - 1));

        return new StudioSettings
        {
            ThemePreference = normalizedTheme,
            DefaultPreviewTheme = previewTheme,
            ReduceMotion = input.ReduceMotion,
            UiDensity = normalizedDensity,
            EditorFontSize = Math.Clamp(input.EditorFontSize, 12, 24),
            TabSize = Math.Clamp(input.TabSize, 2, 8),
            WrapLines = input.WrapLines,
            EnableAutocomplete = input.EnableAutocomplete,
            EnableSlashSuggestions = input.EnableSlashSuggestions,
            AutoRefreshInsights = input.AutoRefreshInsights,
            ProviderPreference = string.IsNullOrWhiteSpace(input.ProviderPreference) ? defaults.ProviderPreference : input.ProviderPreference.Trim().ToLowerInvariant(),
            OllamaEndpoint = string.IsNullOrWhiteSpace(input.OllamaEndpoint) ? defaults.OllamaEndpoint : input.OllamaEndpoint.Trim(),
            OllamaModel = string.IsNullOrWhiteSpace(input.OllamaModel) ? defaults.OllamaModel : input.OllamaModel.Trim(),
            EnableAiContinue = input.EnableAiContinue,
            NativeLlamaCliPath = NormalizePathValue(input.NativeLlamaCliPath),
            NativeLlamaModelDirectory = NormalizePathValue(input.NativeLlamaModelDirectory),
            NativeLlamaGpuModelPath = NormalizePathValue(input.NativeLlamaGpuModelPath),
            NativeLlamaCpuModelPath = NormalizePathValue(input.NativeLlamaCpuModelPath),
            VoiceLanguage = string.IsNullOrWhiteSpace(input.VoiceLanguage) ? defaults.VoiceLanguage : input.VoiceLanguage.Trim(),
            VoiceTranscriptionMode = normalizedVoiceMode,
            EnableLiveInterimTranscript = input.EnableLiveInterimTranscript,
            EnableVoiceCleanup = input.EnableVoiceCleanup,
            VoiceCleanupChunkLength = normalizedChunkLength,
            VoiceCleanupChunkOverlap = normalizedChunkOverlap,
            PersistVoiceAuditTrail = input.PersistVoiceAuditTrail,
            EnablePluginManifest = input.EnablePluginManifest,
            AllowRemotePluginPrompts = input.AllowRemotePluginPrompts,
            PluginManifestPath = string.IsNullOrWhiteSpace(input.PluginManifestPath) ? defaults.PluginManifestPath : input.PluginManifestPath.Trim(),
            MaxLayersPerNote = Math.Clamp(input.MaxLayersPerNote, 50, 500),
            MaxVoiceSessionsPerNote = Math.Clamp(input.MaxVoiceSessionsPerNote, 20, 400),
            EnableTelemetry = input.EnableTelemetry
        };
    }

    private sealed class StudioSettings
